extends templates/tree-template.jade

block title 
  h1 Detailed Breakdown: 2015-17 Adopted Budget 

block datasource
  h6
    | Data source:&nbsp;
    a(href = "https://www.cityofsacramento.gov/finance/budget/documents") City of Sacramento: Budget Documents

block disqus_config
  - var disqusIdentifier = '2015-17 adopted budget tree'

block datafiles
  -
    var treeConfig = {
      dropdownValues: {
        Year: ['FY15-16', 'FY16-17'],
        Account: ['Revenue', 'Expense'],
      },
      dropdownChoice: {
        Year: 'FY16-17',
        Account: 'Expense',
      },
      urlTemplate: 'data/tree/Adopted.{Account}.{Year}.json',
    }
