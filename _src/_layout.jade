doctype html
html(lang='en')
  head
    meta(name='viewport', content='width=device-width')
    link(rel="stylesheet" href="/css/main.css")
    title= title
    if environment == "production"
      //- Google Analytics remains disabled for the Sacramento deployment.
      script(src='/js/hotjar.js', defer)

    script(src='/js/vendor/jquery.min.js').
    script(src='/js/vendor/jquery-migrate-1.2.1.min.js')
    script(src='/js/vendor/bootstrap.min.js').
    script(src='/js/vendor/d3.v3.4.5.min.js').
    script(src='/js/i18n-site.js')

  body(class='#{slug}')
    #wrapper
      nav.main-nav
        .navbar.navbar-default.navbar-fixed-top
          .container
            .navbar-header
              button.navbar-toggle(type='button', data-toggle='collapse', data-target='.navbar-collapse', data-i18n-aria-label='ui.toggleNavigation')
                span.sr-only(data-i18n='ui.toggleNavigation') Toggle navigation
                span.icon-bar
                span.icon-bar
                span.icon-bar
              a.navbar-brand(href='/', data-i18n='ui.siteBrand') Open Budget: Sacramento
            .navbar-collapse.collapse
              ul.nav.navbar-nav.navbar-right

                li.dropdown
                  a.dropdown-toggle(href='#', data-toggle='dropdown')
                    span(data-i18n='nav.about') About
                    b.caret
                  ul.dropdown-menu
                    li
                      a(href='what-we-do.html', data-i18n='nav.whatAndHow') What and How
                    li
                      a(href='who-we-are.html', data-i18n='nav.whoWeAre') Who We Are
                    li
                      a(href='news.html', data-i18n='nav.news') News
                    li
                      a(href='contact.html', data-i18n='nav.contactUs') Contact Us

                li
                  a(href='/budget-visuals.html', data-i18n='nav.visualizations') Visualizations

                li.dropdown
                  a.dropdown-toggle(href='#', data-toggle='dropdown')
                    span(data-i18n='nav.data') Data
                    b.caret
                  ul.dropdown-menu
                    li
                      a(href='https://github.com/code4sac/openbudgetsac.org/wiki/API-Documentation', title='Open Budget Sacramento Docs', aria-label='Open Budget Sacramento Docs') Open Budget Sacramento Docs
                    li
                      a(href='https://www.cityofsacramento.org/-/media/Corporate/Files/Finance/Budget/FY2022_23_ApprovedBudget_Revised_WEB.pdf', title='Adopted Budget Policy Book', aria-label='Adopted Budget Policy Book') Adopted Budget Policy Book
                    li
                      a(href='http://data.codeforsacramento.org/dataset/city-sacramento-budget', title='Legacy Datasets', aria-label='Legacy Datasets') Legacy Datasets

                li.dropdown
                  a.dropdown-toggle(href='#', data-toggle='dropdown')
                    span(data-i18n='nav.resources') Resources
                    b.caret
                  ul.dropdown-menu
                    li
                      a(href='https://www.cityofsacramento.org/Finance/Budget', data-i18n='nav.budget101') Sacramento Budget 101
                    li
                      a(href='tools-projects.html', data-i18n='nav.toolsProjects') Tools and Projects

                  //- li
                  //-   a(href='discuss.html') Discuss

                  li
                    a(href='feedback.html', data-i18n='nav.feedback') Feedback

                li
                  label.sr-only(for='locale-selector-legacy', data-i18n='ui.language') Language
                  select#locale-selector-legacy.form-control.input-sm(data-locale-selector, aria-label='Language', data-i18n-aria-label='ui.language')
                    option(value='en-US', data-i18n='ui.english') English (US)
                    option(value='es-419', data-i18n='ui.spanishLatam') Español (Latinoamérica)

      != yield
      #wrapper-footer

    footer#footer
      .container
        .row
          //-a(rel="license", href="http://creativecommons.org/licenses/by-nc-sa/4.0/")
            img(alt="Creative Commons License", style="border-width:0", src="https://i.creativecommons.org/l/by-nc-sa/4.0/88x31.png")
          .col-md-6.col-sm-9
            p(data-i18n-html='footer.aboutProjectHtml')
              | Open Budget: Sacramento is an open-source project by #{' '}
              a(href="https://opensac.org") Open Sacramento
              |  to help citizens better understand Sacramento's spending and budget process.
            ul.list-inline
              li
                a.social-link(href="https://opensac.org", target='_blank', rel='noopener noreferrer', aria-label='Open Sacramento')
                  img.social-icon(src="/images/global/github-icon.png", alt="Open Sacramento", width="22", height="22")
              li
                a.social-link(href="https://www.x.com/opensacorg", target='_blank', rel='noopener noreferrer', aria-label='Code for Sacramento on X (formerly Twitter)')
                  picture
                    source(srcset="/images/global/x-icon.svg", type="image/svg+xml")
                    img.social-icon(src="/images/global/twitter-icon.png", alt="X (formerly Twitter)", width="22", height="22")
              li
                a.social-link(href="https://github.com/code4sac/openbudgetsac.org", target='_blank', rel='noopener noreferrer', aria-label='Code for Sacramento on GitHub')
                  img.social-icon(src="/images/global/github-icon.png", alt="GitHub", width="22", height="22")


          .col-sm-3.col-md-push-3
            ul.list-unstyled
              li
                a(href="who-we-are.html", data-i18n='nav.aboutProject') About the Project
              li
                a(href="https://www.meetup.com/opensacorg/", data-i18n='nav.getInvolved') Get Involved
              li
                a(href="feedback.html", data-i18n='nav.giveFeedback') Give Feedback

    link(href='https://fonts.googleapis.com/css?family=Arvo:400,700', rel='stylesheet', type='text/css')
