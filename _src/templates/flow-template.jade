.container 
  .row
    .intro.col-md-12
      block title
        
      p(data-i18n='flow.intro1') This diagram depicts the flow of money through Sacramento's budget: from revenue sources (on the left), to the General Fund or various non-discretionary funds (in the center), and finally to the various city departments' expenses (on the right).
      p 
        em(data-i18n='flow.intro2') Mouse over a flow line to highlight it; click on a bar to highlight all its flows.
  .row
    .col-md-3
      h4(data-i18n='flow.fiscalYear') Fiscal Year
      select#fy.form-control

  #sankey
    #chart

  block datasource

  #hover_description

  section#comments
    .row
      .col-md-12
        h4(data-i18n='common.comments') Comments
        #disqus_thread(data-disqus-identifier=typeof disqusIdentifier !== 'undefined' ? disqusIdentifier : 'oboDefault')

block disqus_config
  - var disqusIdentifier = 'oboDefault'

script(src='/js/disqus-loader.js', charset='utf-8', defer)
noscript
  span(data-i18n='common.pleaseEnableJs') Please enable JavaScript to view the
  |  
  a(href='http://disqus.com/?ref_noscript') comments powered by Disqus.

script(src='/js/sankey.js', charset='utf-8')
script(src='/js/flow.js', charset='utf-8')

block get_datafiles

if typeof flowDatafiles !== 'undefined'
  script#flow-datafiles(type='application/json')!= JSON.stringify(flowDatafiles)
script(src='/js/flow-page.js', charset='utf-8', defer)
