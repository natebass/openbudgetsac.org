extends templates/tree-template.jade

block title 
  h1 Detailed Breakdown: 2019-21 Adopted Budget

block datasource
  h6
    | Data source:&nbsp;
    a(href = "https://data.cityofsacramento.org") Sacramento Budget Explorer

block disqus_config
  - var disqusIdentifier = '2019-21 adopted budget tree'

block datafiles
  -
    var treeConfig = {
      dropdownValues: {
        Year: ['FY19-20', 'FY20-21'],
        Account: ['Revenue', 'Expense'],
      },
      dropdownChoice: {
        Year: 'FY19-20',
        Account: 'Expense',
      },
      urlTemplate: 'data/tree/Adopted.{Account}.{Year}.json',
    }
