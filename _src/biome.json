{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "files": {
    "includes": [
      ".eleventy.ts",
      "eslint.config.ts",
      "jest.config.ts",
      "webpack.config.ts",
      "__tests__/**/*.ts",
      "bench/**/*.ts",
      "js/**/*.ts",
      "js/**/*.tsx",
      "scripts/**/*.ts",
      "test/**/*.ts",
      "types/**/*.d.ts"
    ],
    "ignoreUnknown": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "suspicious": {
        "noExplicitAny": "off",
        "noImplicitAnyLet": "off"
      }
    }
  },
  "assist": {
    "enabled": false
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "jsxQuoteStyle": "single",
      "quoteProperties": "asNeeded",
      "trailingCommas": "all",
      "arrowParentheses": "asNeeded",
      "bracketSpacing": false
    }
  }
}
