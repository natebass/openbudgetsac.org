extends templates/tree-template.jade

block title 
  h1 Detailed Breakdown: 2017-19 Mayor's Proposed Budget

block datasource
  h6
    | Data source:&nbsp;
    a(href = "https://data.cityofsacramento.org") Sacramento Budget Explorer

block disqus_config
  - var disqusIdentifier = '2017-19 proposed budget tree'

block datafiles
  -
    var treeConfig = {
      dropdownValues: {
        Year: ['FY17-18', 'FY18-19'],
        Account: ['Revenue', 'Expense'],
      },
      dropdownChoice: {
        Year: 'FY17-18',
        Account: 'Expense',
      },
      urlTemplate: 'data/tree/Proposed.{Account}.{Year}.json',
    }
