extends templates/tree-template.jade

block title 
  h1 Detailed Breakdown: 2016-17 Adjusted Budget 

block datasource
  h6
    | Data source:&nbsp;
    a(href='/files/BudgetData for Public Adopted FY2016-17 Midcycle.xlsx') BudgetData for Public Adopted FY2016-17 Midcycle
  h6 Data provided by City of Sacramento staff; publication on #[a(href="https://data.cityofsacramento.org") data.cityofsacramento.org] pending as of 8/23/16.

block disqus_config
  - var disqusIdentifier = '2016-17 adjusted budget tree'

block datafiles
  -
    var treeConfig = {
      dropdownValues: {
        Year: ['FY16-17'],
        Account: ['Revenue', 'Expense'],
      },
      dropdownChoice: {
        Year: 'FY16-17',
        Account: 'Expense',
      },
      urlTemplate: 'data/tree/Adjusted.{Account}.{Year}.json',
    }
