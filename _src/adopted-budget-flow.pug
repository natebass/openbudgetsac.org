extends partials/layout

prepend pageTitle
  - var title = "Cash Flow"

block bodyClass
  - var slug = "flow"

block content
  .container
    .row
      .intro.col-md-12
        h2= title
        include partials/flowIntro
    .row
      .col-md-3
        label.h4(for='fy', data-i18n='flow.fiscalYear') Fiscal Year
        select#fy.form-control(aria-label='Select fiscal year', data-i18n-aria-label='flow.selectFiscalYear')
    #sankey
      #chart

    #hover_description
    
    -
      var fileNames = [
        {filename: "FY13.csv"},
        {filename: "FY14.csv"},
        {filename: "FY15.csv"},
        {filename: "FY16.csv"},
        {filename: "FY17.csv"},
        {filename: "FY18.csv"},
        {filename: "FY19.csv"},
        {filename: "FY20.csv"},
        {filename: "FY21.csv"},
        {filename: "FY22.csv"},
        {filename: "FY23.csv"},
        {filename: "FY24.csv"},
        {filename: "FY25.csv"},
        {filename: "FY26.csv"},
      ]
    each fileObj in fileNames
      input(class="filename-data", type="hidden", value=fileObj.filename)
      
    include partials/flowScripts
